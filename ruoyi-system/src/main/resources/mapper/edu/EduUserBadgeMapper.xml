<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.edu.mapper.EduUserBadgeMapper">

    <resultMap type="com.ruoyi.edu.domain.EduUserBadge" id="EduUserBadgeResult">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="badgeId" column="badge_id"/>
        <result property="earnedTime" column="earned_time"/>
        <result property="isDisplayed" column="is_displayed"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectEduUserBadgeVo">
        select id, user_id, badge_id, earned_time, is_displayed, create_time, update_time
        from edu_user_badge
    </sql>

    <select id="selectUserBadge" resultMap="EduUserBadgeResult">
        <include refid="selectEduUserBadgeVo"/>
        where user_id = #{userId} and badge_id = #{badgeId}
    </select>

    <select id="selectUserBadgeList" resultMap="EduUserBadgeResult">
        <include refid="selectEduUserBadgeVo"/>
        where user_id = #{userId}
        order by earned_time desc
    </select>

    <insert id="insertEduUserBadge" parameterType="com.ruoyi.edu.domain.EduUserBadge" useGeneratedKeys="true" keyProperty="id">
        insert into edu_user_badge (user_id, badge_id, earned_time, is_displayed, create_time)
        values (#{userId}, #{badgeId}, #{earnedTime}, #{isDisplayed}, sysdate())
    </insert>

    <update id="updateEduUserBadge" parameterType="com.ruoyi.edu.domain.EduUserBadge">
        update edu_user_badge
        <set>
            <if test="earnedTime != null">earned_time = #{earnedTime},</if>
            <if test="isDisplayed != null">is_displayed = #{isDisplayed},</if>
            update_time = sysdate()
        </set>
        where user_id = #{userId} and badge_id = #{badgeId}
    </update>

    <delete id="deleteUserBadge">
        delete from edu_user_badge where user_id = #{userId} and badge_id = #{badgeId}
    </delete>

</mapper>
