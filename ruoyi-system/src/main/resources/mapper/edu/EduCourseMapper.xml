<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.edu.mapper.EduCourseMapper">

    <resultMap type="com.ruoyi.edu.domain.EduCourse" id="EduCourseResult">
        <result property="courseId" column="course_id"/>
        <result property="courseName" column="course_name"/>
        <result property="courseCode" column="course_code"/>
        <result property="categoryId" column="category_id"/>
        <result property="language" column="language"/>
        <result property="level" column="level"/>
        <result property="courseType" column="course_type"/>
        <result property="description" column="description"/>
        <result property="coverImage" column="cover_image"/>
        <result property="trailerVideo" column="trailer_video"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="totalDuration" column="total_duration"/>
        <result property="totalLessons" column="total_lessons"/>
        <result property="totalStudents" column="total_students"/>
        <result property="rating" column="rating"/>
        <result property="ratingCount" column="rating_count"/>
        <result property="isFree" column="is_free"/>
        <result property="price" column="price"/>
        <result property="isPublished" column="is_published"/>
        <result property="isFeatured" column="is_featured"/>
        <result property="prerequisites" column="prerequisites"/>
        <result property="learningObjectives" column="learning_objectives"/>
        <result property="tags" column="tags"/>
        <result property="difficultyScore" column="difficulty_score"/>
        <result property="popularityScore" column="popularity_score"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createDept" column="create_dept"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectEduCourseVo">
        select course_id, course_name, course_code, category_id, language, level, course_type,
               description, cover_image, trailer_video, teacher_id, total_duration, total_lessons,
               total_students, rating, rating_count, is_free, price, is_published, is_featured,
               prerequisites, learning_objectives, tags, difficulty_score, popularity_score,
               del_flag, create_dept, create_by, create_time, update_by, update_time
        from edu_course
        where del_flag = '0'
    </sql>

    <select id="selectEduCourseById" parameterType="Long" resultMap="EduCourseResult">
        <include refid="selectEduCourseVo"/>
        and course_id = #{courseId}
    </select>

    <select id="selectEduCourseList" parameterType="com.ruoyi.edu.domain.EduCourse" resultMap="EduCourseResult">
        <include refid="selectEduCourseVo"/>
        <if test="courseName != null and courseName != ''">
            AND course_name like concat('%', #{courseName}, '%')
        </if>
        <if test="language != null and language != ''">
            AND language = #{language}
        </if>
        <if test="level != null and level != ''">
            AND level = #{level}
        </if>
        <if test="courseType != null and courseType != ''">
            AND course_type = #{courseType}
        </if>
        <if test="categoryId != null">
            AND category_id = #{categoryId}
        </if>
        order by create_time desc
    </select>

    <select id="selectEduCourseByLanguage" parameterType="String" resultMap="EduCourseResult">
        <include refid="selectEduCourseVo"/>
        and language = #{language}
        order by popularity_score desc
    </select>

    <select id="selectEduCourseByLevel" parameterType="String" resultMap="EduCourseResult">
        <include refid="selectEduCourseVo"/>
        and level = #{level}
        order by rating desc
    </select>

    <select id="selectFeaturedCourses" parameterType="Integer" resultMap="EduCourseResult">
        <include refid="selectEduCourseVo"/>
        and is_featured = 1
        order by rating desc
        limit #{limit}
    </select>

    <select id="selectPopularCourses" parameterType="Integer" resultMap="EduCourseResult">
        <include refid="selectEduCourseVo"/>
        order by total_students desc
        limit #{limit}
    </select>

    <select id="selectMyCourses" resultMap="EduCourseResult">
        <include refid="selectEduCourseVo"/>
        and course_id in
        <foreach collection="courseIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <insert id="insertEduCourse" parameterType="com.ruoyi.edu.domain.EduCourse" useGeneratedKeys="true" keyProperty="courseId">
        insert into edu_course
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">course_name,</if>
            <if test="courseCode != null">course_code,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="language != null and language != ''">language,</if>
            <if test="level != null and level != ''">level,</if>
            <if test="courseType != null">course_type,</if>
            <if test="description != null">description,</if>
            <if test="coverImage != null">cover_image,</if>
            <if test="trailerVideo != null">trailer_video,</if>
            <if test="teacherId != null">teacher_id,</if>
            <if test="totalDuration != null">total_duration,</if>
            <if test="totalLessons != null">total_lessons,</if>
            <if test="isFree != null">is_free,</if>
            <if test="price != null">price,</if>
            <if test="isPublished != null">is_published,</if>
            <if test="isFeatured != null">is_featured,</if>
            <if test="prerequisites != null">prerequisites,</if>
            <if test="learningObjectives != null">learning_objectives,</if>
            <if test="tags != null">tags,</if>
            <if test="difficultyScore != null">difficulty_score,</if>
            <if test="popularityScore != null">popularity_score,</if>
            <if test="createDept != null">create_dept,</if>
            <if test="createBy != null">create_by,</if>
            create_time,
            del_flag,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">#{courseName},</if>
            <if test="courseCode != null">#{courseCode},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="language != null and language != ''">#{language},</if>
            <if test="level != null and level != ''">#{level},</if>
            <if test="courseType != null">#{courseType},</if>
            <if test="description != null">#{description},</if>
            <if test="coverImage != null">#{coverImage},</if>
            <if test="trailerVideo != null">#{trailerVideo},</if>
            <if test="teacherId != null">#{teacherId},</if>
            <if test="totalDuration != null">#{totalDuration},</if>
            <if test="totalLessons != null">#{totalLessons},</if>
            <if test="isFree != null">#{isFree},</if>
            <if test="price != null">#{price},</if>
            <if test="isPublished != null">#{isPublished},</if>
            <if test="isFeatured != null">#{isFeatured},</if>
            <if test="prerequisites != null">#{prerequisites},</if>
            <if test="learningObjectives != null">#{learningObjectives},</if>
            <if test="tags != null">#{tags},</if>
            <if test="difficultyScore != null">#{difficultyScore},</if>
            <if test="popularityScore != null">#{popularityScore},</if>
            <if test="createDept != null">#{createDept},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate(),
            '0',
        </trim>
    </insert>

    <update id="updateEduCourse" parameterType="com.ruoyi.edu.domain.EduCourse">
        update edu_course
        <trim prefix="SET" suffixOverrides=",">
            <if test="courseName != null and courseName != ''">course_name = #{courseName},</if>
            <if test="courseCode != null">course_code = #{courseCode},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="language != null and language != ''">language = #{language},</if>
            <if test="level != null and level != ''">level = #{level},</if>
            <if test="courseType != null">course_type = #{courseType},</if>
            <if test="description != null">description = #{description},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="trailerVideo != null">trailer_video = #{trailerVideo},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
            <if test="totalDuration != null">total_duration = #{totalDuration},</if>
            <if test="totalLessons != null">total_lessons = #{totalLessons},</if>
            <if test="isFree != null">is_free = #{isFree},</if>
            <if test="price != null">price = #{price},</if>
            <if test="isPublished != null">is_published = #{isPublished},</if>
            <if test="isFeatured != null">is_featured = #{isFeatured},</if>
            <if test="prerequisites != null">prerequisites = #{prerequisites},</if>
            <if test="learningObjectives != null">learning_objectives = #{learningObjectives},</if>
            <if test="tags != null">tags = #{tags},</if>
            <if test="difficultyScore != null">difficulty_score = #{difficultyScore},</if>
            <if test="popularityScore != null">popularity_score = #{popularityScore},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate(),
        </trim>
        where course_id = #{courseId}
    </update>

    <delete id="deleteEduCourseById" parameterType="Long">
        update edu_course set del_flag = '1' where course_id = #{courseId}
    </delete>

    <delete id="deleteEduCourseByIds" parameterType="Long">
        update edu_course set del_flag = '1' where course_id in
        <foreach item="courseId" collection="array" open="(" separator="," close=")">
            #{courseId}
        </foreach>
    </delete>

    <update id="updateCourseRating">
        update edu_course
        set rating = #{rating},
            rating_count = #{count}
        where course_id = #{courseId}
    </update>

    <update id="incrementStudentCount" parameterType="Long">
        update edu_course
        set total_students = total_students + 1
        where course_id = #{courseId}
    </update>

</mapper>
