<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.edu.mapper.EduLearningProgressMapper">

    <resultMap type="com.ruoyi.edu.domain.EduLearningProgress" id="EduLearningProgressResult">
        <result property="progressId" column="progress_id"/>
        <result property="userId" column="user_id"/>
        <result property="courseId" column="course_id"/>
        <result property="unitId" column="unit_id"/>
        <result property="lessonId" column="lesson_id"/>
        <result property="status" column="status"/>
        <result property="progressPercent" column="progress_percent"/>
        <result property="bestScore" column="best_score"/>
        <result property="attemptCount" column="attempt_count"/>
        <result property="timeSpent" column="time_spent"/>
        <result property="lastStudyTime" column="last_study_time"/>
        <result property="completedTime" column="completed_time"/>
        <result property="nextReviewTime" column="next_review_time"/>
        <result property="masteryLevel" column="mastery_level"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectEduLearningProgressVo">
        select progress_id, user_id, course_id, unit_id, lesson_id, status, progress_percent,
               best_score, attempt_count, time_spent, last_study_time, completed_time,
               next_review_time, mastery_level, create_time, update_time
        from edu_learning_progress
    </sql>

    <select id="selectEduLearningProgressById" parameterType="Long" resultMap="EduLearningProgressResult">
        <include refid="selectEduLearningProgressVo"/>
        where progress_id = #{progressId}
    </select>

    <select id="selectEduLearningProgressByUserAndLesson" resultMap="EduLearningProgressResult">
        <include refid="selectEduLearningProgressVo"/>
        where user_id = #{userId} and lesson_id = #{lessonId}
    </select>

    <select id="selectEduLearningProgressByCourse" resultMap="EduLearningProgressResult">
        <include refid="selectEduLearningProgressVo"/>
        where user_id = #{userId} and course_id = #{courseId}
        order by last_study_time desc
    </select>

    <select id="selectEduLearningProgressList" parameterType="com.ruoyi.edu.domain.EduLearningProgress" resultMap="EduLearningProgressResult">
        <include refid="selectEduLearningProgressVo"/>
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="courseId != null">
                AND course_id = #{courseId}
            </if>
            <if test="unitId != null">
                AND unit_id = #{unitId}
            </if>
            <if test="lessonId != null">
                AND lesson_id = #{lessonId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by last_study_time desc
    </select>

    <insert id="insertEduLearningProgress" parameterType="com.ruoyi.edu.domain.EduLearningProgress" useGeneratedKeys="true" keyProperty="progressId">
        insert into edu_learning_progress
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="courseId != null">course_id,</if>
            <if test="unitId != null">unit_id,</if>
            <if test="lessonId != null">lesson_id,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="progressPercent != null">progress_percent,</if>
            <if test="bestScore != null">best_score,</if>
            <if test="attemptCount != null">attempt_count,</if>
            <if test="timeSpent != null">time_spent,</if>
            <if test="lastStudyTime != null">last_study_time,</if>
            <if test="completedTime != null">completed_time,</if>
            <if test="masteryLevel != null">mastery_level,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="courseId != null">#{courseId},</if>
            <if test="unitId != null">#{unitId},</if>
            <if test="lessonId != null">#{lessonId},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="progressPercent != null">#{progressPercent},</if>
            <if test="bestScore != null">#{bestScore},</if>
            <if test="attemptCount != null">#{attemptCount},</if>
            <if test="timeSpent != null">#{timeSpent},</if>
            <if test="lastStudyTime != null">#{lastStudyTime},</if>
            <if test="completedTime != null">#{completedTime},</if>
            <if test="masteryLevel != null">#{masteryLevel},</if>
        </trim>
    </insert>

    <update id="updateEduLearningProgress" parameterType="com.ruoyi.edu.domain.EduLearningProgress">
        update edu_learning_progress
        <trim prefix="SET" suffixOverrides=",">
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="progressPercent != null">progress_percent = #{progressPercent},</if>
            <if test="bestScore != null">best_score = #{bestScore},</if>
            <if test="attemptCount != null">attempt_count = #{attemptCount},</if>
            <if test="timeSpent != null">time_spent = #{timeSpent},</if>
            <if test="lastStudyTime != null">last_study_time = #{lastStudyTime},</if>
            <if test="completedTime != null">completed_time = #{completedTime},</if>
            <if test="nextReviewTime != null">next_review_time = #{nextReviewTime},</if>
            <if test="masteryLevel != null">mastery_level = #{masteryLevel},</if>
        </trim>
        where progress_id = #{progressId}
    </update>

    <delete id="deleteEduLearningProgressById" parameterType="Long">
        delete from edu_learning_progress where progress_id = #{progressId}
    </delete>

    <delete id="deleteEduLearningProgressByIds" parameterType="Long">
        delete from edu_learning_progress where progress_id in
        <foreach item="progressId" collection="array" open="(" separator="," close=")">
            #{progressId}
        </foreach>
    </delete>

    <select id="countCompletedLessons" resultType="int">
        select count(*) from edu_learning_progress
        where user_id = #{userId}
        and course_id = #{courseId}
        and status = 'completed'
    </select>

    <select id="calculateCourseProgress" resultType="int">
        select
            ifnull(
                (select count(*) from edu_learning_progress
                 where user_id = #{userId}
                 and course_id = #{courseId}
                 and status = 'completed') * 100 / #{total},
                0
            ) as progress
    </select>

    <select id="getUserStreak" resultType="int">
        select coalesce(
            (select current_streak from edu_user_profile where user_id = #{userId}),
            0
        ) as streak
    </select>

    <select id="selectEduLearningProgressByUser" resultMap="EduLearningProgressResult">
        <include refid="selectEduLearningProgressVo"/>
        where user_id = #{userId}
        order by last_study_time desc
    </select>

</mapper>
