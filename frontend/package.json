{
  "name": "lingua-learn-web",
  "version": "1.0.0",
  "description": "LinguaLearn - 多语种在线教育平台前端",
  "author": "LingLearn Team",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .vue,.js,.jsx,.cjs,.mjs src --fix",
    "format": "prettier --write src",
    "server": "json-server --watch db.json --port 3001",
    "start": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "axios": "^1.5.0",
    "echarts": "^5.4.3",
    "element-plus": "^2.3.14",
    "js-cookie": "^3.0.5",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.6",
    "video.js": "^8.5.2",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "json-server": "^1.0.0-beta.15",
    "prettier": "^3.0.3",
    "sass": "^1.66.1",
    "sass-loader": "^13.3.2",
    "unplugin-auto-import": "^0.16.6",
    "unplugin-vue-components": "^0.25.2",
    "vite": "^4.4.9",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-inspector": "^3.4.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
